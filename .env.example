# Supabase (required for gallery + database)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# OpenAI (optional - can be configured in app Settings UI instead)
VITE_OPENAI_API_KEY=your_openai_api_key
VITE_AI_PROVIDER=openai
VITE_OPENAI_MODEL=gpt-image-1

# Optional OpenAI defaults
# VITE_OPENAI_QUALITY=medium
# VITE_OPENAI_STYLE=natural

# Optional Gemini compatibility (used by Vite define -> process.env.API_KEY)
# GEMINI_API_KEY=your_gemini_api_key
